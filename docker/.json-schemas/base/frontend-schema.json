{
  "$schema": "http://json-schema.org/draft-07/schema",
  "properties": {
    "image": {
      "const": "explorviz/frontend:${FRONTEND_IMAGE_TAG}"
    },

    "ports": {
      "type": "array",
      "items": [{ "enum": ["${FRONTEND_PORT}:80"] }]
    },

    "profiles": {
      "type": "array",
      "items": [{ "enum": ["frontend"] }]
    },

    "environment": {
      "type": "array",
      "allOf": [
        {
          "contains": {
            "enum": ["FRONTEND_HOST_URL=http://${FRONTEND_HOSTNAME}:${FRONTEND_PORT}"]
          }
        },
        {
          "contains": {
            "enum": ["FRONTEND_HOSTNAME=${FRONTEND_HOSTNAME}"]
          }
        },
        {
          "contains": {
            "enum": ["CODE_AGENT_URL=http://${CODE_AGENT_HOSTNAME}:${CODE_AGENT_PORT_INTERNAL}"]
          }
        },
        {
          "contains": {
            "enum": ["CODE_SERV_URL=http://${CODE_HOSTNAME}:${CODE_PORT}"]
          }
        },
        {
          "contains": {
            "enum": ["SPAN_SERV_URL=http://${SPAN_HOSTNAME}:${SPAN_PORT_INTERNAL}"]
          }
        },
        {
          "contains": {
            "enum": ["USER_SERV_URL=http://${USER_HOSTNAME}:${USER_PORT_INTERNAL}"]
          }
        },
        {
          "contains": {
            "enum": ["COLLAB_SERV_URL=http://${COLLABORATION_HOSTNAME}:${COLLABORATION_PORT}"]
          }
        },
        {
          "contains": {
            "enum": ["VSCODE_SERV_URL=http://${FRONTEND_HOSTNAME}:${FRONTEND_PORT}"]
          }
        },
        {
          "contains": {
            "enum": ["KEYCLOAK_URL=http://${KEYCLOAK_HOSTNAME}:${KEYCLOAK_PORT}"]
          }
        }
      ]
    }
  },

  "required": ["image", "ports", "environment"]
}
