# Compose Stack
COMPOSE_PROJECT_NAME=explorviz
COMPOSE_PROFILES=env,backend,frontend,generator #,chatbot,auth,monitoring

# Docker Networking
LOCALHOST_ALIAS=host.docker.internal

# ExplorViz Java Images (jvm or native)
EXPLORVIZ_JAVA_IMAGE_TYPE=jvm

# ExplorViz Image Tags
COPILOT_IMAGE_TAG=latest
TRACE_SERVICE_IMAGE_TAG=latest
USER_SERVICE_IMAGE_TAG=latest
FRONTEND_IMAGE_TAG=latest
LANDSCAPE_SERVICE_IMAGE_TAG=latest
CODE_ANALYZER_IMAGE_TAG=latest
VSCODE_IMAGE_TAG=latest

# ExplorViz Hostnames
CODE_ANALYZER_HOSTNAME=code-analyzer
TRACE_HOSTNAME=trace-service
USER_HOSTNAME=user-service
LANDSCAPE_HOSTNAME=landscape-service
COPILOT_HOSTNAME=chatbot-service
VSCODE_HOSTNAME=vs-code-backend

# Environment Hostnames
COLLECTOR_HOSTNAME=otel-collector
KEYCLOAK_HOSTNAME=keycloak
NEO4J_HOSTNAME=neo4j
CLICKHOUSE_HOSTNAME=clickhouse
KAFKA_HOSTNAME=kafka
MONGO_USER_HOSTNAME=user-mongo
PROMETHEUS_HOSTNAME=prometheus
GRAFANA_HOSTNAME=grafana
LAG_EXPORTER_HOSTNAME=kafka-lag-exporter

# Environment Ports
KAFKA_EXT_PORT=9091
KAFKA_INT_PORT=9092
KAFKA_JMX_PORT=9101
OTEL_COLLECTOR_PORT=55678
OTEL_COLLECTOR_ZPAGES_PORT=55679
NEO4J_BROWSER_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_URI=bolt://neo4j:7687
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=19000
MONGO_USER_SERV_PORT=27017
VSCODE_EXT_PORT=3001
VSCODE_INT_PORT=80

# ExplorViz Network
USER_PORT=8080

COPILOT_PORT_INTERNAL=4300
COPILOT_PORT=4300
CODE_ANALYZER_PORT=8078
CODE_ANALYZER_PORT_INTERNAL=8078
TRACE_GENERATOR_PORT=8079
TRACE_PORT=8081
TRACE_PORT_INTERNAL=8080
LANDSCAPE_PORT=8085
LANDSCAPE_PORT_INTERNAL=8085
LANDSCAPE_GRPC_PORT=9000
FRONTEND_PORT=8080
USER_PORT=8084
USER_PORT_INTERNAL=8080
KEYCLOAK_PORT=5657
KEYCLOAK_PORT_INTERNAL=8080

# ExplorViz Frontend
FRONTEND_HOSTNAME=localhost

# ExplorViz Scaling
TRACE_REPLICAS=1

# Monitoring
MONITORING_PROMETHEUS_PORT=9090
MONITORING_NODE_EXPORTER_PORT=9100
MONITORING_CADVISOR_PORT=8080
MONITORING_GRAFANA_PORT=3000


# Keycloak
KEYCLOAK_AUTH_ENABLED=false
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASS=admin
KEYCLOAK_REALM_CONFIG=./configurations/keycloak/explorviz-realm.json
KEYCLOAK_REALM=explorviz
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PWD=password


# user-service auth
USER_SERVICE_KC_CLIENT=frontend
